generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Manager {
  id          String   @id @default(cuid())
  name        String
  phone       String?
  email       String?
  avatar      String?
  position    String?  @default("Sales Manager")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  calls       Call[]
  reports     DailyReport[]
  users       User[]
}

model Call {
  id              String    @id @default(cuid())
  managerId       String
  manager         Manager   @relation(fields: [managerId], references: [id], onDelete: Cascade)
  audioFileName   String
  audioPath       String
  duration        Int?
  transcription   String?
  analysis        String?
  rating          Float?
  problems        String?
  positives       String?
  clientSentiment String?
  callOutcome     String?
  summary         String?
  createdAt       DateTime  @default(now())
  callDate        DateTime  @default(now())
}

model DailyReport {
  id            String   @id @default(cuid())
  managerId     String
  manager       Manager  @relation(fields: [managerId], references: [id], onDelete: Cascade)
  date          DateTime
  totalCalls    Int      @default(0)
  avgRating     Float    @default(0)
  topProblems   String?
  summary       String?
  improvement   String?
  createdAt     DateTime @default(now())

  @@unique([managerId, date])
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("user")
  managerId String?
  manager   Manager? @relation(fields: [managerId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SupportMessage {
  id         String   @id @default(cuid())
  sessionId  String
  userMsg    String
  aiMsg      String
  adminReply String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
}
