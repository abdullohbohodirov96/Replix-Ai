generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Manager {
  id          String        @id @default(cuid())
  name        String
  phone       String?
  email       String?
  avatar      String?
  position    String?       @default("Sales Manager")
  projectId   String?
  project     Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  calls       Call[]
  reports     DailyReport[]
  users       User[]
}

model Project {
  id             String         @id @default(cuid())
  name           String
  adminEmail     String?
  adminPass      String?
  managers       Manager[]
  users          User[]
  callCategories CallCategory[]
  leadCategories LeadCategory[]
  company        Company?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Call {
  id              String        @id @default(cuid())
  managerId       String
  manager         Manager       @relation(fields: [managerId], references: [id], onDelete: Cascade)
  audioFileName   String
  audioPath       String
  audioData       Bytes?
  audioMimeType   String?
  duration        Int?
  clientPhone     String?
  transcription   String?
  analysis        String?
  rating          Float?
  score           Float?
  problems        String?
  positives       String?
  recommendations String?
  improvement     String?
  clientSentiment String?
  callOutcome     String?
  summary         String?
  leadQuality     String?
  status          String        @default("analyzed")
  categoryId      String?
  category        CallCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  archivedAt      DateTime?
  analyzedAt      DateTime?
  createdAt       DateTime      @default(now())
  callDate        DateTime      @default(now())
}

model CallCategory {
  id          String                 @id @default(cuid())
  name        String
  description String?
  color       String                 @default("#3b82f6")
  order       Int                    @default(0)
  isDefault   Boolean                @default(false)
  projectId   String?
  project     Project?               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  calls       Call[]
  criteria    ConversationCriteria[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
}

model ConversationCriteria {
  id          String       @id @default(cuid())
  name        String
  description String?
  categoryId  String
  category    CallCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  weight      Float        @default(1.0)
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model LeadCategory {
  id          String         @id @default(cuid())
  name        String
  label       String
  description String?
  color       String         @default("#f97316")
  order       Int            @default(0)
  projectId   String?
  project     Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  criteria    LeadCriteria[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model LeadCriteria {
  id             String       @id @default(cuid())
  name           String
  description    String?
  leadCategoryId String
  leadCategory   LeadCategory @relation(fields: [leadCategoryId], references: [id], onDelete: Cascade)
  order          Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Company {
  id          String   @id @default(cuid())
  name        String
  description String?
  industry    String?
  aiContext   String?
  projectId   String?  @unique
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DailyReport {
  id            String   @id @default(cuid())
  managerId     String
  manager       Manager  @relation(fields: [managerId], references: [id], onDelete: Cascade)
  date          DateTime
  totalCalls    Int      @default(0)
  avgRating     Float    @default(0)
  topProblems   String?
  summary       String?
  improvement   String?
  createdAt     DateTime @default(now())

  @@unique([managerId, date])
}

model User {
  id              String           @id @default(cuid())
  name            String
  email           String           @unique
  password        String
  role            String           @default("user")
  managerId       String?
  manager         Manager?         @relation(fields: [managerId], references: [id], onDelete: SetNull)
  projectId       String?
  project         Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  supportMessages SupportMessage[]
}

model SupportMessage {
  id         String   @id @default(cuid())
  sessionId  String
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userMsg    String
  aiMsg      String
  adminReply String?
  isRead     Boolean  @default(false)
  wantsAdmin Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Integration {
  id        String    @id @default(cuid())
  name      String    @unique
  enabled   Boolean   @default(false)
  config    Json?
  lastSync  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model AIKnowledge {
  id        String   @id @default(cuid())
  category  String
  pattern   String
  frequency Int      @default(1)
  context   String?
  callId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, pattern])
  @@index([category, frequency])
}
